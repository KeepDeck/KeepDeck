{
  "id": "keepdeck.files",
  "name": "Files",
  "version": "0.1.0",
  "minApiVersion": 12,
  "category": "deck",
  "description": "Browse the workspace file tree and preview file contents, scoped to the workspace folder and its worktrees.",
  "capabilities": [
    {
      "kind": "fs",
      "scope": "workspace"
    },
    {
      "kind": "open"
    }
  ],
  "contributes": {
    "dockTabs": [
      {
        "id": "files",
        "label": "Files"
      }
    ],
    "fileOpeners": [
      {
        "id": "peek",
        "label": "KeepDeck file peek"
      }
    ],
    "settings": true,
    "overlays": [
      {
        "id": "viewer",
        "label": "File peek"
      }
    ]
  }
}
