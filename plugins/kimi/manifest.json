{
  "id": "keepdeck.kimi",
  "name": "Kimi Code",
  "version": "0.1.0",
  "minApiVersion": 25,
  "category": "cli",
  "description": "Adds the Kimi Code CLI with exact session resume and an optional one-time setup for session persistence.",
  "capabilities": [
    { "kind": "exec", "commands": ["kimi", "/bin/sh"] },
    { "kind": "net", "domains": ["127.0.0.1"] },
    { "kind": "notifications" },
    { "kind": "fs", "scope": "everywhere" },
    { "kind": "fsWrite", "paths": ["~/.kimi-code"] }
  ],
  "contributes": {
    "agents": [{ "id": "kimi", "label": "Kimi Code" }],
    "settings": true
  }
}
