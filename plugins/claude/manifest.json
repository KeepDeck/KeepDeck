{
  "id": "keepdeck.claude",
  "name": "Claude Code",
  "version": "0.1.0",
  "minApiVersion": 21,
  "category": "cli",
  "description": "Teaches KeepDeck the Claude Code CLI: catalog identity and detection; spawn, resume and session identity move in next.",
  "capabilities": [
    { "kind": "exec", "commands": ["claude"] },
    { "kind": "fs", "scope": "everywhere" },
    { "kind": "fsWrite", "paths": ["~/.claude/projects"] }
  ],
  "contributes": {
    "agents": [{ "id": "claude", "label": "Claude Code" }]
  }
}
