{
  "id": "keepdeck.opencode",
  "name": "OpenCode",
  "version": "0.1.0",
  "minApiVersion": 27,
  "category": "cli",
  "description": "Teaches KeepDeck the OpenCode CLI: identity and detection, spawn/resume/fork with session relocation, session-store history, and pane usage.",
  "capabilities": [
    { "kind": "exec", "commands": ["opencode"] },
    { "kind": "sqliteReadonly", "paths": ["~/.local/share/opencode"] },
    { "kind": "fs", "scope": "everywhere" },
    { "kind": "fsWrite", "paths": ["/tmp/keepdeck-opencode", "/private/tmp/keepdeck-opencode"] },
    { "kind": "notifications" }
  ],
  "contributes": {
    "agents": [{ "id": "opencode", "label": "OpenCode" }]
  }
}
