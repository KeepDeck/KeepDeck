{
  "id": "keepdeck.opencode",
  "name": "OpenCode",
  "version": "0.1.0",
  "minApiVersion": 25,
  "category": "cli",
  "description": "Teaches KeepDeck the OpenCode CLI: catalog identity and detection; spawn, resume and session identity move in next.",
  "capabilities": [
    { "kind": "exec", "commands": ["opencode"] },
    { "kind": "sqliteReadonly", "paths": ["~/.local/share/opencode"] }
  ],
  "contributes": {
    "agents": [{ "id": "opencode", "label": "OpenCode" }]
  }
}
